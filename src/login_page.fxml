<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginController">
   <children>
      <TextField fx:id="idField" layoutX="104.0" layoutY="106.0" promptText="Enter Your ID" />
      <Button fx:id="loginButton" layoutX="104.0" layoutY="219.0" mnemonicParsing="false" onAction="#handleLogin" text="Login" />
      <Button fx:id="registerButton" layoutX="187.0" layoutY="219.0" mnemonicParsing="false" onAction="#handleRegister" text="Regester" />
      <Button fx:id="adminButton" layoutX="491.0" layoutY="339.0" mnemonicParsing="false" onAction="#handleAdminLogin" text="Admain Login" />
      <PasswordField fx:id="passwordField" layoutX="101.0" layoutY="154.0" promptText="Enter your Password" />
      <Label fx:id="messageLabel" ellipsisString="" layoutX="312.0" layoutY="170.0" />
   </children>
</AnchorPane>
