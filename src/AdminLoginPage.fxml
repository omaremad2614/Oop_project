<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="700.0" prefWidth="1000.0" styleClass="admin-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="adminController">
   <children>

      <VBox alignment="CENTER" maxWidth="440.0" maxHeight="520.0" spacing="18.0" styleClass="admin-card">
         <children>

            <Label styleClass="admin-title" text="Admin Access" />
            <Label styleClass="admin-subtitle" text="Sign in to the administration panel" />
            <Region prefHeight="12.0" />

            <VBox spacing="6.0" alignment="CENTER_LEFT">
               <Label styleClass="admin-field-label" text="ADMIN ID" />
               <TextField fx:id="idField" promptText="Enter your admin ID" styleClass="admin-text-field" />
            </VBox>

            <VBox spacing="6.0" alignment="CENTER_LEFT">
               <Label styleClass="admin-field-label" text="PASSWORD" />
               <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="admin-text-field" />
            </VBox>

            <Label fx:id="messageLabel" styleClass="message-label" text="" wrapText="true" />
            <Region prefHeight="8.0" />

            <Button maxWidth="Infinity" onAction="#handleAdminLogin" styleClass="admin-login-btn" text="SIGN IN" />
            <Region prefHeight="8.0" />
            <Button onAction="#handleBack" styleClass="admin-link-btn" text="← Go back to student login" />

         </children>
      </VBox>

   </children>
</StackPane>