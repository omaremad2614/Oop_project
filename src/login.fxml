<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginController">
   <children>
      <AnchorPane layoutX="5.0" layoutY="-26.0" prefHeight="606.0" prefWidth="600.0" stylesheets="@../../../Downloads/style.css">
         <children>
            <VBox alignment="CENTER" layoutX="150.0" layoutY="50.0" prefHeight="390.0" prefWidth="300.0" spacing="14" styleClass="card">
               <padding>
                  <Insets bottom="36" left="30" right="30" top="36" />
               </padding>
               <children>
                  <Label styleClass="title-label" text="Welcome Back" />
                  <Label styleClass="subtitle-label" text="Sign in to your account" />
                  <Label styleClass="field-label" text="ID NUMBER" />
                  <TextField fx:id="idField" promptText="Enter your 9-digit ID" styleClass="text-field" />
                  <Label styleClass="field-label" text="PASSWORD" />
                  <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="password-field" />
                  <Label fx:id="messageLabel" maxWidth="300" prefWidth="238.0" styleClass="message-label" text="" wrapText="true" />
                  <Button onAction="#handleLogin" styleClass="login-btn" text="Sign In" />
                  <Button onAction="#handleRegister" styleClass="register-btn" text="Create Account" />
                  <HBox alignment="CENTER_RIGHT" prefWidth="300">
                     <children>
                        <Button onAction="#handleAdminLogin" styleClass="admin-btn" text="Admin Login" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
