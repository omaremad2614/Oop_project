<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #F4F7F6;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="StudentDashboardController">
    <children>
        <VBox minWidth="240.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: #1C2541;">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <children>
                <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 22px; -fx-font-weight: bold;" text="Student Portal" />
                <Region prefHeight="30.0" />
                <Button maxWidth="Infinity" style="-fx-text-fill: #E5B80B; -fx-background-color: transparent; -fx-border-color: #E5B80B; -fx-border-radius: 6; -fx-font-weight: bold; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" text="🎓 My Dashboard" />
                <Button maxWidth="Infinity" onAction="#handleOpenCatalog" style="-fx-text-fill: #A0AAB2; -fx-background-color: transparent; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-cursor: hand;" text="📖 Course Catalog" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#handleSignOut" style="-fx-text-fill: #FF6B6B; -fx-background-color: transparent; -fx-border-color: #FF6B6B; -fx-border-radius: 6; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-cursor: hand;" text="🚪 Sign Out" />
            </children>
        </VBox>

        <VBox spacing="24.0" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <Label fx:id="welcomeLabel" style="-fx-font-size: 28px; -fx-text-fill: #1C2541; -fx-font-weight: bold;" text="Welcome back" />

                <HBox spacing="20.0">
                    <VBox prefWidth="180.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #1C2541; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="STUDENT ID" />
                        <Label fx:id="idLabel" style="-fx-text-fill: #1C2541; -fx-font-size: 24px; -fx-font-weight: bold;" text="---" />
                    </VBox>
                    <VBox prefWidth="180.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #1C2541; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="TERM" />
                        <Label fx:id="termLabel" style="-fx-text-fill: #1C2541; -fx-font-size: 24px; -fx-font-weight: bold;" text="---" />
                    </VBox>
                    <VBox prefWidth="180.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #1C2541; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="CUMULATIVE GPA" />
                        <Label fx:id="gpaLabel" style="-fx-text-fill: #1C2541; -fx-font-size: 24px; -fx-font-weight: bold;" text="---" />
                    </VBox>
                </HBox>

                <Label text="My Registered Courses &amp; Grades" style="-fx-text-fill: #1C2541; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 10 0 0 0;" />
                <TableView fx:id="courseTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #1C2541; -fx-border-width: 2; -fx-border-radius: 6; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colCode" prefWidth="100.0" text="COURSE" />
                        <TableColumn fx:id="colName" prefWidth="200.0" text="COURSE NAME" />
                        <TableColumn fx:id="colWk7" prefWidth="100.0" text="WEEK 7 (30)" />
                        <TableColumn fx:id="colWk12" prefWidth="100.0" text="WEEK 12 (20)" />
                        <TableColumn fx:id="colCW" prefWidth="100.0" text="C. WORK (10)" />
                        <TableColumn fx:id="colFinal" prefWidth="100.0" text="FINAL (40)" />
                        <TableColumn fx:id="colTotal" prefWidth="100.0" style="-fx-font-weight: bold;" text="TOTAL" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</HBox>