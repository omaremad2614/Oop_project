<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F4F7F6;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dashboardController">
   <children>

      <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #1C2541;">
         <padding>
            <Insets left="32.0" right="32.0" />
         </padding>
         <children>
            <StackPane alignment="CENTER">
               <HBox.margin><Insets right="12.0" /></HBox.margin>
               <children>
                  <Circle radius="18.0" fill="#E5B80B" />
                  <Label style="-fx-text-fill: #1C2541; -fx-font-weight: bold;" text="M" />
               </children>
            </StackPane>
            <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: bold;" text="Arab Academy" />

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button onAction="#handleOpenDashboard" style="-fx-background-color: transparent; -fx-text-fill: #A0AAB2; -fx-cursor: hand; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" text="My Dashboard" />
                  <Button onAction="#handleSignOut" style="-fx-background-color: transparent; -fx-text-fill: #FF6B6B; -fx-border-color: #FF6B6B; -fx-border-radius: 6; -fx-cursor: hand; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" text="Sign Out" />
               </children>
            </HBox>
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: #F4F7F6;" VBox.vgrow="ALWAYS">
         <content>
            <VBox>
               <VBox>
                  <padding>
                     <Insets bottom="20.0" left="48.0" right="48.0" top="36.0" />
                  </padding>
                  <children>
                     <Label style="-fx-text-fill: #1C2541; -fx-font-size: 28px; -fx-font-weight: bold;" text="Course Catalog" />
                     <Label style="-fx-text-fill: #64748B; -fx-font-size: 14px;" text="Select a course below to view details and register." />
                     <Region maxWidth="Infinity" prefHeight="2.0" style="-fx-background-color: #E2E8F0;">
                        <VBox.margin><Insets top="20.0" /></VBox.margin>
                     </Region>
                  </children>
               </VBox>

               <TilePane fx:id="courseContainer" hgap="25.0" prefColumns="2" vgap="25.0">
                  <padding>
                     <Insets bottom="40.0" left="48.0" right="48.0" top="10.0" />
                  </padding>
               </TilePane>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</VBox>