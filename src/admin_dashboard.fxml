<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="700.0" prefWidth="1100.0" styleClass="admin-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="adminDashboardController">
    <children>
        <VBox minWidth="240.0" prefWidth="240.0" spacing="10.0" styleClass="admin-sidebar">
            <children>
                <Label styleClass="admin-title" text="Faculty Portal" />
                <Region prefHeight="30.0" />
                <Button maxWidth="Infinity" style="-fx-text-fill: #E5B80B; -fx-background-color: #1C2541; -fx-background-radius: 6;" styleClass="admin-sidebar-btn" text="📚 My Gradebook" />
                <Region VBox.vgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#handleSignOut" styleClass="admin-sidebar-btn" text="🚪 Sign Out" />
            </children>
        </VBox>

        <VBox spacing="20.0" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
            </padding>
            <children>
                <Label fx:id="welcomeLabel" style="-fx-font-size: 24px;" styleClass="admin-title" text="Welcome, Professor" />
                <Label text="Double-click any student in the table to view their full profile." textFill="#a0aab2" />

                <TableView fx:id="studentTable" styleClass="admin-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="colName" prefWidth="180.0" text="NAME" />
                        <TableColumn fx:id="colWk7" prefWidth="90.0" text="WEEK 7 (30)" />
                        <TableColumn fx:id="colWk12" prefWidth="90.0" text="WEEK 12 (20)" />
                        <TableColumn fx:id="colCW" prefWidth="90.0" text="C. WORK (10)" />
                        <TableColumn fx:id="colFinal" prefWidth="90.0" text="FINAL (40)" />
                        <TableColumn fx:id="colTotal" prefWidth="90.0" text="TOTAL (100)" />
                    </columns>
                </TableView>

                <VBox spacing="10" style="-fx-background-color: #1C2541; -fx-padding: 20; -fx-background-radius: 8;">

                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <Label text="Update Grades for Selected Student:" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Simulate System Time:" style="-fx-text-fill: #A0AAB2;"/>
                        <ComboBox fx:id="weekSimulator" styleClass="admin-text-field" prefWidth="180" />
                    </HBox>

                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <TextField fx:id="wk7Field" promptText="Week 7 (Max 30)" prefWidth="120" styleClass="admin-text-field"/>
                        <TextField fx:id="wk12Field" promptText="Week 12 (Max 20)" prefWidth="120" styleClass="admin-text-field"/>
                        <TextField fx:id="cwField" promptText="C. Work (Max 10)" prefWidth="120" styleClass="admin-text-field"/>
                        <TextField fx:id="finalField" promptText="Final (Max 40)" prefWidth="120" styleClass="admin-text-field"/>

                        <Region HBox.hgrow="ALWAYS" />

                        <CheckBox fx:id="finalizeBox" minWidth="-Infinity" text="Finalize Grade" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                        <Button minWidth="-Infinity" onAction="#handleSaveMarks" text="💾 SAVE MARKS" style="-fx-background-color: #E5B80B; -fx-text-fill: #070D1F; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" /></HBox>
                    <Label fx:id="messageLabel" text="" textFill="#FF5252"/>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>